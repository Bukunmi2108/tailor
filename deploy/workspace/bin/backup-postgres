#!/usr/bin/env bash
set -Eeuo pipefail

readonly BACKUP_ROOT=/opt/workspace/backups/postgres
readonly STAMP="$(date -u +%Y%m%dT%H%M%SZ)"
readonly DESTINATION="$BACKUP_ROOT/workspace-$STAMP.sql.gz"
readonly TEMPORARY="$DESTINATION.tmp"

install -d -m 0700 "$BACKUP_ROOT"
docker exec workspace-postgres pg_dumpall --clean --if-exists -U workspace_admin \
  | gzip -9 > "$TEMPORARY"
test -s "$TEMPORARY"
mv "$TEMPORARY" "$DESTINATION"
find "$BACKUP_ROOT" -type f -name 'workspace-*.sql.gz' -mtime +14 -delete
